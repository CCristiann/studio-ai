# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ── NextAuth ──
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# ── Plugin Token JWT (RS256, ADR 2026-04-15) ──
# Generate the keypair locally:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out plugin-jwt.key
#   openssl pkey -in plugin-jwt.key -pubout -out plugin-jwt.pub
# Paste PEM contents below. Newlines may be encoded as literal \n if your host
# doesn't accept multi-line env values (Vercel/Railway both accept either form).
# Web needs BOTH (signs with private, verifies with public).
# API needs ONLY the public key.
PLUGIN_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
PLUGIN_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_STUDIO_PRICE_ID=price_...

# ── FastAPI Relay ──
FASTAPI_URL=http://localhost:8000
FASTAPI_INTERNAL_API_KEY=generate-a-strong-secret
# Comma-separated browser origins allowed to call the relay (CORS). Must be explicit — wildcard is rejected.
ALLOWED_ORIGINS=http://localhost:3000

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── AI ──
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
